{
    "brand": {
        "name": "AutoLock",
        "identity": "arcane_tech"
    },
    "colors": {
        "background": {
            "app": "#091428",
            "panel": "#0A1428",
            "card": "#0A1428",
            "overlay": "rgba(0,0,0,0.6)"
        },
        "text": {
            "primary": "#F0E6D2",
            "secondary": "#C8AA6E",
            "muted": "#6C757D",
            "disabled": "#3A4654"
        },
        "accent": {
            "primary": "#C8AA6E",
            "gold": "#C8AA6E",
            "blue": "#0BC6E3",
            "green": "#2ECC71",
            "red": "#E74C3C",
            "purple": "#9B59B6"
        },
        "state": {
            "success": "#2ECC71",
            "warning": "#F1C40F",
            "danger": "#E74C3C",
            "info": "#3498DB",
            "hover": "#1C2630"
        }
    },
    "gradients": {
        "panel": [
            "#0E141B",
            "#0A0F14"
        ],
        "card": [
            "#141E28",
            "#0E141B"
        ],
        "header": [
            "#111A23",
            "#0A0F14"
        ],
        "gold_glow": [
            "#C8A45D33",
            "#00000000"
        ],
        "blue_glow": [
            "#3FA9F533",
            "#00000000"
        ]
    },
    "elevation": {
        "level0": {
            "shadow": "none",
            "blur": 0
        },
        "level1": {
            "shadow": "0 2px 6px rgba(0,0,0,0.4)",
            "blur": 6
        },
        "level2": {
            "shadow": "0 6px 16px rgba(0,0,0,0.45)",
            "blur": 12
        },
        "level3": {
            "shadow": "0 10px 28px rgba(0,0,0,0.5)",
            "blur": 18
        },
        "level4": {
            "shadow": "0 16px 40px rgba(0,0,0,0.6)",
            "blur": 26
        }
    },
    "radius": {
        "xs": 4,
        "sm": 6,
        "md": 10,
        "lg": 14,
        "xl": 18,
        "pill": 999
    },
    "spacing": {
        "xs": 4,
        "sm": 8,
        "md": 12,
        "lg": 16,
        "xl": 24,
        "xxl": 32
    },
    "borders": {
        "subtle": "1px solid #1E2328",
        "soft": "1px solid #1E2328",
        "strong": "1px solid #3C3C41",
        "gold": "1px solid #C8AA6E"
    },
    "buttons": {
        "primary": {
            "bg": "#C8AA6E",
            "text": "#091428",
            "hover": "#D3B679",
            "glow": "0 0 12px rgba(200,170,110,0.6)"
        },
        "secondary": {
            "bg": "transparent",
            "text": "#C8AA6E",
            "hover": "#1E2328",
            "glow": "0 0 10px rgba(200,170,110,0.4)"
        },
        "danger": {
            "bg": "transparent",
            "text": "#E74C3C",
            "hover": "#C0392B",
            "glow": "0 0 12px rgba(231,76,60,0.6)"
        },
        "ghost": {
            "bg": "transparent",
            "text": "#F0E6D2",
            "hover": "#1E2328"
        }
    },
    "animations": {
        "hover": {
            "scale": 1.02,
            "duration": 120
        },
        "press": {
            "scale": 0.97,
            "duration": 80
        },
        "float": {
            "offset": 4,
            "duration": 200
        },
        "fade": {
            "duration": 160
        },
        "card_float": {
            "lift_px": 2,
            "duration": 150,
            "border_glow": "#C8A45D40"
        },
        "focus_ring": {
            "color": "#3FA9F5",
            "width": 2,
            "duration": 100
        }
    },
    "icons": {
        "style": "glyph_glow",
        "glow_color": "#C8A45D",
        "glow_intensity": 0.6
    },
    "typography": {
        "font_primary": "Spiegel",
        "font_secondary": "Beaufort for LoL",
        "weights": {
            "regular": 400,
            "medium": 500,
            "bold": 700
        }
    }
}